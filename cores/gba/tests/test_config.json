    "memory_bus": {
      "name": "Bus / Boundary Crossing",
      "description": "Wait-state and access-width behavior crossing the 128KB EWRAM bank boundary mid-transfer.",
      "subsystem": "memory",
      "priority": "medium",
      "repo": "nba-hw-test",
      "tests": [
        {"path": "bus/128kb-boundary/128kb-boundary.gba", "expected": "pass", "accuracy_type": "timing", "result_detection": "serial", "priority": "medium",
         "source_url": "https://github.com/nba-emu/hw-test", "license": "see upstream",
         "notes": "EWRAM is a 256KB chip mirrored; transfers crossing 128KB exercise the wrap."}
      ]
    },

    "memory_unsafe": {
      "name": "Unsafe / Undefined Memory",
      "description": "SRAM mirroring and unused-ROM (out-of-bounds) open-bus reads. Behavior is board-dependent; not guaranteed on hardware.",
      "subsystem": "memory",
      "priority": "low",
      "repo": "jsmolka",
      "tests": [
        {"path": "unsafe/unsafe.gba", "expected": "known_fail", "accuracy_type": "functional", "result_detection": "serial", "priority": "low",
