{
  "schema_version": 2,
  "console": "gba",
  "description": "Veloce GBA core authoritative test suite. Subsystem-organized, prioritized, with per-test result-detection. Goal: state with evidence how architecturally correct AND cycle-accurate the GBA core is. Detection: jsmolka/alyosha/FuzzARM ROMs spin with R12 = failing test # (0 = pass); the Veloce GBA plugin detects the stable-PC spin loop and prints '[GBA] PASSED' / '[GBA] FAILED - Failed at test #N' (parsed by the 'serial' family detector, GBA sub-variant). Visual ROMs are captured via SAVE_SCREENSHOT and CRC32-compared. Interactive ROMs (mGBA suite, armwrestler) have no headless auto-verdict and are marked known_fail/RUNS until a screenshot reference is pinned.",
  "timeout_seconds": 60,
  "frame_limit": 1200,

  "repositories": {
    "jsmolka": {
      "url": "https://github.com/jsmolka/gba-tests.git",
      "dir": "gba-test-roms",
      "type": "git",
      "license": "MIT (jsmolka/gba-tests)",
      "description": "Canonical CPU (ARM/Thumb), memory, BIOS, PPU smoke, save-type tests. Fail # in R12."
    },
    "alyosha": {
      "url": "https://github.com/alyosha-tas/gba-tests.git",
      "dir": "alyosha-gba-tests",
      "type": "git",
      "license": "MIT (fork of jsmolka/gba-tests)",
      "description": "Extended timing/IRQ/DMA/prefetch/LDM/interaction/PSR cycle-accuracy tests (fork of jsmolka)."
    },
    "nba-hw-test": {
      "url": "https://github.com/nba-emu/hw-test.git",
      "dir": "nba-hw-test",
      "type": "git",
      "license": "see upstream (NanoBoyAdvance hw-test)",
      "description": "NanoBoyAdvance hardware tests: DMA latch/start-delay, IRQ delay, timer, PPU status IRQ/DMA, HALTCNT, bus boundary."
    },
    "fuzzarm": {
      "url": "https://github.com/DenSinH/FuzzARM.git",
      "dir": "fuzzarm",
      "type": "git",
      "license": "see upstream (DenSinH/FuzzARM)",
      "description": "Randomized 10k-iteration ARM/Thumb instruction fuzz ROMs (prebuilt .gba). On-screen pass/fail."
    },
    "armwrestler": {
      "url": "https://github.com/destoer/armwrestler-gba-fixed.git",
      "dir": "armwrestler",
      "type": "git",
      "license": "see upstream (armwrestler, destoer fork)",
      "description": "ARMWrestler ALU + multi load/store correctness ROM (interactive, on-screen)."
    }
  },

  "test_suites": {

    "cpu_arm": {
      "name": "ARM Instruction Set",
      "description": "ARM mode: conditions, branches, flags, shifts, data processing, PSR transfer, multiply, single/halfword transfer, swap, block transfer (LDM/STM). Spans ~600 sub-tests; fail # in R12.",
      "subsystem": "cpu",
      "priority": "critical",
      "repo": "jsmolka",
      "tests": [
        {"path": "arm/arm.gba", "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "critical",
         "source_url": "https://github.com/jsmolka/gba-tests", "license": "MIT",
         "notes": "Comprehensive ARM instruction correctness. R12=0 on full pass."}
      ]
    },

    "cpu_thumb": {
      "name": "Thumb Instruction Set",
      "description": "Thumb mode: all 19 formats incl. BLX, PUSH/POP edge cases, hi-reg ops, conditional/unconditional branch. Fail # in R12.",
      "subsystem": "cpu",
      "priority": "critical",
      "repo": "jsmolka",
      "tests": [
        {"path": "thumb/thumb.gba", "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "critical",
         "source_url": "https://github.com/jsmolka/gba-tests", "license": "MIT",
         "notes": "Comprehensive Thumb instruction correctness. R12=0 on full pass."}
      ]
    },

    "cpu_psr": {
      "name": "PSR / CPSR-SPSR",
      "description": "Program status register transfer/banking (MRS/MSR, mode switches, SPSR per mode, flag bits).",
      "subsystem": "cpu",
      "priority": "high",
      "repo": "alyosha",
      "tests": [
        {"path": "psr/psr.gba", "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "high",
         "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT"}
      ]
    },

    "cpu_ldm": {
      "name": "LDM/STM Block Transfer Edge Cases",
      "description": "Load/store-multiple corner cases that break naive cores: base-in-list writeback, PC in list (mode/Thumb switch), S-bit banked transfer, LDM combined with ALU/MUL/SWP/BX.",
      "subsystem": "cpu",
      "priority": "high",
      "repo": "alyosha",
      "tests": [
        {"path": "LDM/LDM_ALU.gba",        "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "high", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT", "notes": "LDM followed by ALU op (timing/value interaction)."},
        {"path": "LDM/LDM_ALU_IMM.gba",    "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "high", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT"},
        {"path": "LDM/LDM_ALU_Store.gba",  "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "high", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT"},
        {"path": "LDM/LDM_Bx.gba",         "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "high", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT", "notes": "LDM loading PC then BX (ARM/Thumb state switch)."},
        {"path": "LDM/LDM_LD.gba",         "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "high", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT"},
        {"path": "LDM/LDM_MUL_UL_32.gba",  "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "high", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT"},
        {"path": "LDM/LDM_MUL_UL_SL.gba",  "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "high", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT"},
        {"path": "LDM/LDM_Swap.gba",       "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "high", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT", "notes": "LDM interleaved with SWP (bus locking)."}
      ]
    },

    "cpu_alyosha_core": {
      "name": "Alyosha ARM/Thumb Core (cross-check)",
      "description": "Independent ARM/Thumb correctness ROMs from the alyosha fork plus targeted Thumb edge ROMs (BLX, CPY, PUSH/POP with no regs).",
      "subsystem": "cpu",
      "priority": "high",
      "repo": "alyosha",
      "tests": [
        {"path": "arm/arm.gba",            "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "high", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT"},
        {"path": "thumb/thumb.gba",        "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "high", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT"},
        {"path": "thumb/blx.gba",          "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "high", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT", "notes": "Thumb BLX(2) reg form."},
        {"path": "thumb/cpy.gba",          "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "medium", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT"},
        {"path": "thumb/Push_no_regs.gba", "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "medium", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT", "notes": "PUSH with empty reg list: SP -= 0x40 quirk."},
        {"path": "thumb/Pop_no_regs.gba",  "expected": "pass", "accuracy_type": "functional", "result_detection": "serial", "priority": "medium", "source_url": "https://github.com/alyosha-tas/gba-tests", "license": "MIT", "notes": "POP with empty reg list: SP += 0x40, PC loaded from [SP] quirk."}
      ]
    },

    "cpu_fuzz": {
      "name": "FuzzARM Randomized CPU Fuzz",
      "description": "DenSinH/FuzzARM: 10k randomized iterations per ROM covering ARM/Thumb data-processing and all-type ops, cross-checked against a reference. On-screen pass/fail (no R12 spin); headless verdict not auto-extractable yet so marked known_fail pending a screenshot reference or a debug-string build.",
      "subsystem": "cpu",
      "priority": "high",
      "repo": "fuzzarm",
      "tests": [
        {"path": "ARM_DataProcessing.gba",   "expected": "known_fail", "accuracy_type": "functional", "result_detection": "serial", "priority": "high",   "source_url": "https://github.com/DenSinH/FuzzARM", "license": "see upstream", "notes": "10k ARM data-processing fuzz. Reports on screen; needs OCR/screenshot ref for headless verdict."},
        {"path": "ARM_Any.gba",              "expected": "known_fail", "accuracy_type": "functional", "result_detection": "serial", "priority": "high",   "source_url": "https://github.com/DenSinH/FuzzARM", "license": "see upstream", "notes": "10k ARM all-type fuzz."},
        {"path": "THUMB_DataProcessing.gba", "expected": "known_fail", "accuracy_type": "functional", "result_detection": "serial", "priority": "high",   "source_url": "https://github.com/DenSinH/FuzzARM", "license": "see upstream", "notes": "10k Thumb data-processing fuzz."},
        {"path": "THUMB_Any.gba",            "expected": "known_fail", "accuracy_type": "functional", "result_detection": "serial", "priority": "high",   "source_url": "https://github.com/DenSinH/FuzzARM", "license": "see upstream", "notes": "10k Thumb all-type fuzz."},
        {"path": "FuzzARM.gba",              "expected": "known_fail", "accuracy_type": "functional", "result_detection": "serial", "priority": "medium", "source_url": "https://github.com/DenSinH/FuzzARM", "license": "see upstream", "notes": "10k any-mode any-type fuzz."}
      ]
    },

    "cpu_armwrestler": {
      "name": "ARMWrestler ALU + Load/Store",
      "description": "destoer armwrestler-gba-fixed: ARM ALU and the notoriously tricky multiple load/store (test4) cases. Interactive menu ROM; no headless verdict, captured as a visual smoke / RUNS.",
      "subsystem": "cpu",
      "priority": "medium",
      "repo": "armwrestler",
      "tests": [
        {"path": "armwrestler-gba-fixed.gba", "expected": "known_fail", "accuracy_type": "functional", "result_detection": "serial", "priority": "medium",
         "source_url": "https://github.com/destoer/armwrestler-gba-fixed", "license": "see upstream",
         "notes": "Interactive; spins waiting for input. Document as manual-only until a pinned screenshot reference exists."}
      ]
    },

    "memory_access": {
      "name": "Memory Map / Mirroring / Width",
      "description": "Region mirroring (IWRAM/EWRAM/Palette/VRAM/OAM), 8/16/32-bit access width, misaligned access rotation, BIOS/IO open-bus reads.",
