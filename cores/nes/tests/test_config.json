  "known_issues": {
    "cpu_interrupts": "NMI/BRK hijacking now passes. NMI/IRQ (test 3) has 1-cycle timing edge case with APU frame counter",
    "mmc3_scanline_timing": "mmc3_test_2/4-scanline_timing expects IRQ at scanline 261 cycle 157 (6976 cycles from VBL) but A12 first rises at cycle 261 (7080 cycles from VBL) during sprite pattern fetch with $2000=$08. The equivalent mmc3_irq_tests/4.Scanline_timing passes with tolerance. Investigation shows the test expects A12 to rise during BG fetches when BG is at $0000 which appears inconsistent with MMC3 A12 clocking behavior.",
    "unstable_opcodes": "LAX immediate ($AB) and other unstable 6502 opcodes have hardware-dependent behavior",
    "apu_timing": "APU frame counter edge timing varies between models - affects jitter and length counter tests"
  }
